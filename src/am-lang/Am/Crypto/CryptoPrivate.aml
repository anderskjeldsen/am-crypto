namespace Am.Crypto
{
    class CryptoPrivate
    {
        import Am.Lang

        private static fun openSslInitialized(): Bool {
            if (!Runtime.has("openssl-initialized")) {
                return false
            }
            return Runtime.get("openssl-initialized") == "true"
        }

        private static fun setOpenSslInitialized() {
            Runtime.set("openssl-initialized", "true")
        }
    }
}